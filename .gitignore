# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
# .env.example is intentionally tracked — it contains no real secrets

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# java / maven
target/
*.class
*.jar
*.war
*.zip

# spring secrets — never commit real credentials
raprank-backend/src/main/resources/application.properties

# go binaries
*.exe
/raprank-upload/raprank-upload

# python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.venv/
venv/
ENV/
**/__pycache__/

# BeatLyrix local uploads & generated test outputs
/raprank-upload/uploads/audio/*.mp3
raprank-nlp/*.txt
raprank-nlp/*.log
raprank-nlp/test_out.html

# Ad-hoc scratch/debug files at repo root -- may contain scraped/copyrighted
# lyric text pasted in during manual testing, never for commit.
/lyrics_temp.txt
/payload_temp.json

# Local-only real-corpus reference model (trained on scraped corpus/data/
# lyric text) -- deliberately kept outside raprank-nlp/ and out of the repo
# entirely, since a trained artifact derived from scraped copyrighted lyrics
# should never be committed.
/local_real_model/

# Kaggle datasets and notebooks — contain raw lyric text or phoneme artifacts
# derived from copyrighted corpus; all local-only, never committed.
/kaggle_rap_data/
/kaggle_dataset/
/kaggle_lyrics_dataset/
/kaggle_barsnet/
/kaggle_barsnet_cpu/
/kaggle_classifier/
/kaggle_classifier_synth/
/kaggle_g2p/

# Root-level scraped lyrics files — copyrighted raw text, local-only.
/scraped_lyrics*.json
/scraped_*.json

# Root-level trained model artifacts derived from scraped corpus.
/barsnet.pt
/barsnet_pretrained.pt
/barsnet_history.json
/barsnet_meta_out.json
