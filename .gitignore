# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
# .env.example is intentionally tracked — it contains no real secrets

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# java / maven
target/
*.class
*.jar
*.war
*.zip

# spring secrets — never commit real credentials
raprank-backend/src/main/resources/application.properties

# go binaries
*.exe
/raprank-upload/raprank-upload

# python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.venv/
venv/
ENV/
**/__pycache__/

# BeatLyrix local uploads & generated test outputs
/raprank-upload/uploads/audio/*.mp3
raprank-nlp/*.txt
raprank-nlp/*.log
raprank-nlp/test_out.html

# Ad-hoc scratch/debug files at repo root -- may contain scraped/copyrighted
# lyric text pasted in during manual testing, never for commit.
/lyrics_temp.txt
/payload_temp.json

# Local-only real-corpus reference model (trained on scraped corpus/data/
# lyric text) -- deliberately kept outside raprank-nlp/ and out of the repo
# entirely, since a trained artifact derived from scraped copyrighted lyrics
# should never be committed.
/local_real_model/*.pkl

# Kaggle English-rap lyrics dataset (Genius-scraped, copyrighted) -- same
# treatment as local_real_model/: raw lyric text and anything derived from
# it stays local-only, never committed.
/kaggle_rap_data/
