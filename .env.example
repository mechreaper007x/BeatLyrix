# ─────────────────────────────────────────────────────────────────────────────
# RapRank — Local Development Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL password (used by both postgres service and Spring Boot)
DB_PASSWORD=raprank123

# JWT signing secret (min 32 characters)
# Generate a strong one: openssl rand -base64 48
JWT_SECRET=raprank-super-secret-key-minimum-32-chars-long-2026

# Hugging Face Whisper Space URL
# Leave as-is to use the deployed HF Space.
# Override with http://localhost:7860 if running whisper locally.
WHISPER_API_URL=https://mechreaper007x-raprank-whisper.hf.space
